{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "clean:next": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev": "next dev --webpack -p 3010",
    "dev:clean": "npm run clean:next && npm run dev",
    "build": "next build --webpack",
    "start": "next start -p 3010",
    "lint": "eslint",
    "typecheck": "node ../../node_modules/@typescript/native/bin/tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "npx tsx scripts/migrate-sqlite-to-pg.ts"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "pg": "^8.22.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "server-only": "^0.0.1",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript/native": "npm:typescript@^7.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
