{
    "name": "lotto",
    "version": "1.0.0",
    "engines": {
        "node": ">=24 <25"
    },
    "workspaces": [
        "apps/web",
        "apps/api"
    ],
    "scripts": {
        "check:node": "node -e \"const ok=process.versions.modules==='137'; if(!ok){console.error('Node 24.x 필요 (현재 '+process.version+', modules='+process.versions.modules+')'); process.exit(1)}\"",
        "predev": "npm run check:node",
        "dev": "npm run dev:raw",
        "dev:raw": "concurrently \"npm run dev -w web\" \"npm run dev:api\"",
        "rebuild:sqlite:node24": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& \\\"$env:ProgramFiles\\\\nodejs\\\\node.exe\\\" \\\"$env:ProgramFiles\\\\nodejs\\\\node_modules\\\\npm\\\\bin\\\\npm-cli.js\\\" rebuild better-sqlite3 --workspace api\"",
        "dev:web:node24": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& \\\"$env:ProgramFiles\\\\nodejs\\\\node.exe\\\" \\\"$env:ProgramFiles\\\\nodejs\\\\node_modules\\\\npm\\\\bin\\\\npm-cli.js\\\" run dev -w web\"",
        "dev:api:node24": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& \\\"$env:ProgramFiles\\\\nodejs\\\\node.exe\\\" \\\"$env:ProgramFiles\\\\nodejs\\\\node_modules\\\\npm\\\\bin\\\\npm-cli.js\\\" run start:dev -w api\"",
        "dev:raw:node24": "concurrently \"npm run dev:web:node24\" \"npm run dev:api:node24\"",
        "dev:node24": "npm run rebuild:sqlite:node24 && npm run dev:raw:node24",
        "dev:web": "npm run dev -w web",
        "dev:web:clean": "npm run dev:clean -w web",
        "dev:api": "npm run start:dev -w api",
        "db:copy": "npm run db:copy -w api",
        "build": "npm run build -w web",
        "build:api": "npm run build -w api",
        "start": "npm run start -w web",
        "lint": "npm run lint -w web",
        "test:api": "npm run test -w api",
        "cursor-sdk:example": "node scripts/cursor-sdk-example.mjs"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.1",
        "autoprefixer": "^10.4.27",
        "concurrently": "^9.2.1",
        "dotenv": "^17.4.2",
        "postcss": "^8.5.6",
        "tailwindcss": "^4.2.1"
    },
    "dependencies": {
        "@cursor/sdk": "^1.0.10"
    }
}
