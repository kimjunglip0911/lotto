{
    "name": "lotto",
    "version": "1.0.0",
    "engines": {
        "node": ">=24 <25"
    },
    "workspaces": [
        "apps/web"
    ],
    "scripts": {
        "check:node": "node -e \"const ok=process.versions.modules==='137'; if(!ok){console.error('Node 24.x 필요 (현재 '+process.version+', modules='+process.versions.modules+')'); process.exit(1)}\"",
        "predev": "npm run check:node",
        "dev": "npm run dev -w web",
        "dev:web": "npm run dev -w web",
        "dev:web:clean": "npm run dev:clean -w web",
        "db:migrate": "npm run db:migrate -w web",
        "build": "npm run build -w web",
        "typecheck": "npm run typecheck -w web",
        "start": "npm run start -w web",
        "lint": "npm run lint -w web",
        "cursor-sdk:example": "node scripts/cursor-sdk-example.mjs"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.1",
        "autoprefixer": "^10.4.27",
        "dotenv": "^17.4.2",
        "postcss": "^8.5.6",
        "tailwindcss": "^4.2.1"
    },
    "dependencies": {
        "@cursor/sdk": "^1.0.10"
    }
}
